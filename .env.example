# Copy to `.env` and fill in real values before `docker compose up`.
# Both vars are lab-internal only; regenerate if they ever leave the box.

# Shared secret between Grafana and the image-renderer container.
# Generate with: openssl rand -hex 32
RENDERER_TOKEN=__REPLACE_ME__

# First-boot admin password for Grafana (ignored after the user exists in the volume).
GRAFANA_ADMIN_PASSWORD=__REPLACE_ME__
